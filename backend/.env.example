# Clé secrète pour la signature des tokens JWT.
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacer-par-une-cle-aleatoire-longue

# Algorithme JWT (ne pas modifier)
ALGORITHM=HS256

# Identifiants de connexion de la secrétaire
GLOBAL_USERNAME=secretaire
GLOBAL_PASSWORD=remplacer-par-un-mot-de-passe-fort

# Durée de validité des tokens en minutes (600 = 10h)
ACCESS_TOKEN_EXPIRE_MINUTES=600

# Informations du cabinet (affichées dans l'interface)
NOM_CABINET=Cabinet Dentaire
TELEPHONE_CABINET=0100000000
